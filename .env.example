# Copy this file to .env and replace placeholders with your real API keys.
# Never commit .env to git.

# LLM provider: anthropic (default) or openai (OpenRouter, Together, Groq, Ollama)
LLM_PROVIDER=anthropic
# openai
# --- Anthropic (when LLM_PROVIDER=anthropic) ---
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- OpenAI-compatible (when LLM_PROVIDER=openai) ---
# OpenRouter: https://openrouter.ai/api/v1
# Together:   https://api.together.xyz/v1
# Groq:       https://api.groq.com/openai/v1
# Ollama:     http://localhost:11434/v1  (OPENAI_API_KEY=ollama)
# OPENAI_API_KEY=your_openrouter_or_compatible_api_key_here
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_MODEL=meta-llama/llama-3.3-70b-instruct

# --- Web search (always required) ---
TAVILY_API_KEY=your_tavily_api_key_here
